# Simple commands for running your bot.
.PHONY: help setup run chat doctor web update service stop

help:
	@echo "make setup   - configure the bot (run this first)"
	@echo "make run     - start the bot"
	@echo "make chat    - quick AI test in the terminal"
	@echo "make doctor  - check everything is working"
	@echo "make web     - open the status page in your browser"
	@echo "make update  - reinstall dependencies"
	@echo "make service - run the bot 24/7 in the background"
	@echo "make stop    - stop the background bot"

setup:
	uv run mika setup

run:
	uv run mika run

chat:
	uv run mika chat "hello"

doctor:
	uv run mika doctor

web:
	uv run mika web

update:
	uv sync --no-dev

service:
	uv run mika service install

stop:
	uv run mika service stop
