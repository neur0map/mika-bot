# Mika configuration. Copy to `.env` (or let `mika setup` write it). Placeholders
# only — never commit real secrets. All keys load through src/mika/core/config.py.

# ── Runtime ──────────────────────────────────────────────────────────────────
MIKA_ENV=production
MIKA_LOG_LEVEL=info
MIKA_DATA_DIR=./var
MIKA_DATABASE_URL=sqlite+aiosqlite:///./var/mika.sqlite3

# ── Discord (official Bot API) ───────────────────────────────────────────────
DISCORD_TOKEN=CHANGEME
DISCORD_CLIENT_ID=CHANGEME
# Comma-separated guild IDs allowed to use the bot (empty = all guilds it joins)
DISCORD_GUILD_IDS=
# Channels where the bot replies WITHOUT being @mentioned (empty = mention-only)
DISCORD_RESPONSE_CHANNEL_IDS=

# ── Identity / persona (the ONLY place the bot's name is set; rebrandable) ────
MIKA_PERSONA_NAME=Mika
MIKA_PERSONA_FILE=./config/persona.md

# ── LLM (OpenAI-compatible: OpenRouter / Groq / Together / OpenAI) ────────────
MIKA_LLM_PROVIDER=openrouter
MIKA_LLM_BASE_URL=https://openrouter.ai/api/v1
MIKA_LLM_API_KEY=CHANGEME
MIKA_LLM_MODEL=openai/gpt-4o-mini
MIKA_LLM_TEMPERATURE=0.8
MIKA_LLM_MAX_TOKENS=600
# Optional fallback provider (used if the primary call fails)
MIKA_LLM_FALLBACK_BASE_URL=
MIKA_LLM_FALLBACK_API_KEY=
MIKA_LLM_FALLBACK_MODEL=

# ── Memory ───────────────────────────────────────────────────────────────────
MIKA_MEMORY_RECENT_WINDOW=20
# Honcho semantic memory is optional (needs the Honcho docker stack running)
MIKA_MEMORY_HONCHO_ENABLED=false
MIKA_MEMORY_HONCHO_BASE_URL=http://127.0.0.1:8000
MIKA_MEMORY_HONCHO_WORKSPACE=default
MIKA_MEMORY_HONCHO_SESSION=default

# ── Tools (the AI's internet access) ─────────────────────────────────────────
MIKA_TOOLS_WEB_SEARCH_ENABLED=true
MIKA_TOOLS_WEB_SEARCH_MAX_RESULTS=4
MIKA_TOOLS_WEB_SEARCH_TIMEOUT=8.0

# ── Web (localhost settings & overview page) ─────────────────────────────────
MIKA_WEB_HOST=127.0.0.1
MIKA_WEB_PORT=8080
MIKA_WEB_SECRET=CHANGEME
