# Mika configuration template.
# Copy to `.env` (gitignored) or let `mika setup` write it. Values here are
# placeholders — never commit real secrets. All keys are prefixed MIKA_ except
# the Discord ones, and load through src/mika/core/config.py.

# ── Runtime ──────────────────────────────────────────────────────────────────
MIKA_ENV=production
MIKA_LOG_LEVEL=info
MIKA_DATA_DIR=./var

# ── Discord (official Bot API) ───────────────────────────────────────────────
DISCORD_TOKEN=CHANGEME
DISCORD_CLIENT_ID=CHANGEME
# Comma-separated guild IDs allowed to use the bot (empty = all guilds it joins)
DISCORD_GUILD_IDS=

# ── LLM (OpenAI-compatible: OpenRouter / Groq / Together / OpenAI) ────────────
MIKA_LLM_PROVIDER=openrouter
MIKA_LLM_BASE_URL=https://openrouter.ai/api/v1
MIKA_LLM_API_KEY=CHANGEME
MIKA_LLM_MODEL=x-ai/grok-4.3
# Optional fallback provider
MIKA_LLM_FALLBACK_BASE_URL=https://api.groq.com/openai/v1
MIKA_LLM_FALLBACK_API_KEY=
MIKA_LLM_FALLBACK_MODEL=llama-3.3-70b-versatile

# ── Persistence ──────────────────────────────────────────────────────────────
MIKA_DATABASE_URL=sqlite+aiosqlite:///./var/mika.sqlite3

# ── Web (localhost settings & overview page) ─────────────────────────────────
MIKA_WEB_HOST=127.0.0.1
MIKA_WEB_PORT=8080
MIKA_WEB_SECRET=CHANGEME
